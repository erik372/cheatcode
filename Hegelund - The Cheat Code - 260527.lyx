caps "false"
noprefix "false"
nolink "false"

\end_inset

 we have the two time series A and B.
 For each year 
\begin_inset Formula $t$
\end_inset

 an index can be calculated by dividing the value for this year with the value for the base year.
 Index year 
\begin_inset Formula $t$
\end_inset

 is then:
 
\begin_inset Formula 
\begin{equation}
\text{Index}_{t}=\frac{\text{Value}_{t}}{\text{Value}_{\text{base year}}}*100\label{eq:index def}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
Now we shall create one index per time series,
 using the first year in each series as the base year.
 The index value for time series A year 2007 is:
 
\begin_inset Formula 
\begin{align}
\text{Index A}_{2007} & =100*\frac{\text{Time series A}_{2007}}{\text{Time series A}_{2007}}=100*\frac{123}{123}=21.7
\end{align}

\end_inset


\end_layout

\begin_layout Standard
For the year 2010 we get:
 
\begin_inset Formula 
\begin{align}
\text{Index A}_{2010} & =100*\frac{\text{Time series A}_{2010}}{\text{Time series A}_{2007}}=100*\frac{207}{123}\approx168.3
\end{align}

\end_inset


\end_layout

\begin_layout Standard
The last year for time series A is 2012:
\begin_inset Formula 
\begin{equation}
\text{Index A}_{2012}=100*\frac{199}{123}\approx161.8
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
For time series B the first year is 2010:
\begin_inset Formula 
\begin{align}
\text{Index B}_{2010} & =100*\frac{\text{Time series B}_{2010}}{\text{Time series B}_{2010}}=100*\frac{2}{2}=100
\end{align}

\end_inset


\end_layout

\begin_layout Standard
The index value year 2015 for time series B:
 
\begin_inset Formula 
\begin{align}
\text{Index B}_{2015} & =100*\frac{6.3}{2}=315
\end{align}

\end_inset


\end_layout

