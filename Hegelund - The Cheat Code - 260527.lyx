\end_layout

\begin_layout Standard

\family typewriter
# Create chart
\end_layout

\begin_layout Standard

\family typewriter
ggplot(aes(x=x)) + 
\end_layout

\begin_layout Standard

\family typewriter
geom_histogram(alpha=.3,
 
\end_layout

