noprefix "false"
nolink "false"

\end_inset

 shows an example with the matrices:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
Z=\left[\begin{matrix}2 & 1\\
1 & 3
\end{matrix}\right],\,C=\left[\begin{matrix}3\\
3
\end{matrix}\right],\,S=\left[\begin{matrix}6\\
7
\end{matrix}\right]
\end{equation}

\end_inset


\end_layout

