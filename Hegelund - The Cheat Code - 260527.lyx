\begin_layout Standard
\begin_inset Formula 
\begin{equation}
Y=\left(I-A\right)^{-1}S=\left[\begin{matrix}\frac{8}{5} & \frac{2}{5}\\
\frac{7}{15} & \frac{28}{15}
\end{matrix}\right]*\left[\begin{matrix}6\\
7
\end{matrix}\right]=\left[\begin{matrix}12.4\\
15.9
\end{matrix}\right]
\end{equation}

