name "sec:Interaktion"

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Note Note
status open

\begin_layout Plain Layout
detta avsnitt ska vara ok
\end_layout

\end_inset


\begin_inset Index idx
range none
pageformat default
status open

\begin_layout Plain Layout
regression!model
\end_layout

\end_inset


\begin_inset Index idx
range none
