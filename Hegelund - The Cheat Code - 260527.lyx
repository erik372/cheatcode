\begin_inset Formula $y$
\end_inset

 and all observations have the values 
\begin_inset Formula $\left(x,y\right)=\left(5,23\right)$
\end_inset

,
 then there is no variation within variable 
\begin_inset Formula $x$
\end_inset

 or 
\begin_inset Formula $y$
\end_inset

.
 The variables therefore cannot covary either.
\end_layout

\begin_layout Standard
