\begin_layout Standard
Let us estimate variance (section 
\begin_inset CommandInset ref
LatexCommand ref
reference "sec:Varians-och-standardavvikelse"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) for each variable.
 Variance for the variable life expectancy 
\begin_inset Formula $\left(L\right)$
\end_inset

:
\begin_inset Formula 
\begin{align}
var\left(L\right)= & \frac{\sum_{i}\left(L_{i}-\bar{L}\right)^{2}}{n-1}=\frac{341.1156}{5}\approx68.22\label{eq: est var ex 1}
\end{align}

\end_inset

where 
\begin_inset Formula $L_{i}-\bar{L}$
\end_inset

 indicates the deviation from the mean for the variable life expectancy.
 Variance for GDP per capita,
 variable 
\begin_inset Formula $G$
\end_inset

,
 is:
\begin_inset Formula 
\begin{align}
var\left(G\right)= & \frac{\sum_{i}\left(G_{i}-\bar{G}\right)^{2}}{n-1}=373.886
\end{align}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Float figure
placement document
